generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int         @id @default(autoincrement())
  email      String      @unique
  password   String
  createdAt  DateTime    @default(now())

  affiliates Affiliate[]
}

model Affiliate {
  id             Int      @id @default(autoincrement())
  firstName      String
  lastName       String
  email          String
  membershipType String

  userId Int
  user   User @relation(fields: [userId], references: [id])
}