<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <title>DentPlus</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">


  <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/">DentPlus</a>

      <div class="d-flex gap-2">
        <a class="btn btn-outline-light btn-sm" href="/affiliates">
          Afiliados
        </a>
        {{#if userId}} <form action="/logout" method="POST" class="m-0"> <button class="btn btn-outline-warning btn-sm"
            type="submit"> Cerrar sesión </button> </form> {{/if}}
      </div>
  </nav>

  <main class="container">
    <div class="card shadow-sm">
      <div class="card-body">
        {{{body}}}
      </div>
    </div>
  </main>

</body>

</html>