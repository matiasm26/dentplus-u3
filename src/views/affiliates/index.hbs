<h1 class="mb-3">Afiliados DentPlus</h1>

<div class="mb-3">
    <a class="btn btn-primary" href="/affiliates/create">Crear nuevo afiliado</a>
    <a class="btn btn-secondary" href="/">Volver al inicio</a>
</div>

<ul class="list-group">
    {{#each affiliates}}
    <li class="list-group-item d-flex justify-content-between align-items-center">
        <span>
            {{firstName}} {{lastName}} - <strong>{{membershipType}}</strong>
        </span>

        <a class="btn btn-sm btn-outline-primary" href="/affiliates/{{id}}">
            Ver detalle
        </a>
    </li>
    {{else}}
    <li class="list-group-item">No hay afiliados registrados.</li>
    {{/each}}
</ul>