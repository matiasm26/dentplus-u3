<h1>Detalle del afiliado</h1>

<p><strong>ID:</strong> {{affiliate.id}}</p>
<p><strong>Nombre:</strong> {{affiliate.firstName}}</p>
<p><strong>Apellido:</strong> {{affiliate.lastName}}</p>
<p><strong>Email:</strong> {{affiliate.email}}</p>
<p><strong>Afiliación:</strong> {{affiliate.membershipType}}</p>
<br><br>

<a href="/affiliates/{{affiliate.id}}/edit">
    Editar afiliado
</a>
<form action="/affiliates/{{affiliate.id}}/delete" method="POST">
    <button type="submit">Eliminar afiliado</button>
</form>

<a href="/affiliates">Volver al listado</a>