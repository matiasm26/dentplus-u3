<h1 class="mb-3">Editar afiliado</h1>

<form action="/affiliates/{{affiliate.id}}/edit" method="POST">
    <div class="mb-3">
        <label class="form-label">Nombre:</label>

        <input class="form-control" type="text" name="firstName" value="{{affiliate.firstName}}" required>
    </div>

    <div class="mb-3">
        <label class="form-label">Apellido:</label>

        <input class="form-control" type="text" name="lastName" value="{{affiliate.lastName}}" required>
    </div>

    <div class="mb-3">
        <label class="form-label">Email:</label>

        <input class="form-control" type="email" name="email" value="{{affiliate.email}}" required>
    </div>

    <div class="mb-3">
        <label class="form-label">Tipo afiliación:</label>

        <select class="form-select" name="membershipType">
            <option value="silver">Silver</option>
            <option value="gold">Gold</option>
            <option value="platinum">Platinum</option>
        </select>
    </div>

    <button class="btn btn-primary" type="submit">
        Guardar cambios
    </button>

    <a class="btn btn-secondary" href="/affiliates/{{affiliate.id}}">
        Volver al detalle
    </a>
</form>